# Analytics
ANALYTICS_SUBNET=172.39.2.0/24

# Your Spotify (mongo:4.4 used — required for ARM/Raspberry Pi)
YOUR_SPOTIFY_SERVER_IP=172.39.2.2
YOUR_SPOTIFY_CLIENT_IP=172.39.2.3
YOUR_SPOTIFY_MONGO_IP=172.39.2.4

YOUR_SPOTIFY_API_PORT=8282
YOUR_SPOTIFY_CLIENT_PORT=3000

# Must match the redirect URI registered in your Spotify developer dashboard
# e.g. http://homeserver:8282
YOUR_SPOTIFY_API_ENDPOINT=http://YOUR_SERVER_IP:8282
# e.g. http://homeserver:3000
YOUR_SPOTIFY_CLIENT_ENDPOINT=http://YOUR_SERVER_IP:3000

# Spotify app credentials — https://developer.spotify.com/dashboard
SPOTIFY_PUBLIC=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_SECRET=YOUR_SPOTIFY_CLIENT_SECRET

TZ=Europe/Dublin
YOUR_SPOTIFY_LOG_LEVEL=info
