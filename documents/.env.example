# Random secret key for paperless-ngx — generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
PAPERLESS_SECRET_KEY=

# API token for paperless-gpt to talk to paperless-ngx — get it after first run:
# docker compose exec paperless-ngx python3 manage.py drf_create_token <your-admin-username>
PAPERLESS_API_TOKEN=

PAPERLESS_BASE_URL=http://paperless-ngx:8000

PAPERLESS_API_URL=http://paperless-ngx:8001

# Host user/group that owns the data directories
PUID=1000
PGID=1000

TZ=Europe/Dublin

OLLAMA_HOST=http://192.168.0.x:11434 # LAN IP of the machine running Ollama (not the Pi)

# Postgres database for paperless-ngx
PAPERLESS_DB_USERNAME=
PAPERLESS_DB_PASSWORD=
PAPERLESS_DB_NAME=

# Paperless-ai service
PAPERLESS_API_URL=http://paperless-ngx:8000/api
PAPERLESS_USERNAME=lexcode # change to your paperless username
AI_PROVIDER=ollama
OLLAMA_API_URL=${OLLAMA_HOST}
OLLAMA_MODEL=qwen3:8b
RAG_SERVICE_URL=http://paperless-ngx:8000
RAG_SERVICE_ENABLED=true
SCAN_INTERVAL=*/30 * * * *
PAPERLESS_URL=http://paperless-ngx:8000