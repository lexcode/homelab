PUID=1000
PGID=1000
TZ=Europe/Dublin

# Docker bridge for *arr + vpn; *_IP must fall inside SERVARR_SUBNET (used by compose ipv4_address)
SERVARR_SUBNET=172.39.0.0/24

VPN_IP=172.39.0.2
SONARR_IP=172.39.0.3
RADARR_IP=172.39.0.4
LIDARR_IP=172.39.0.5
BAZARR_IP=172.39.0.6
SEERR_IP=172.39.0.7
PROWLARR_IP=172.39.0.8
FLARESOLVERR_IP=172.39.0.10

WEBUI_PORT=8080
TORRENTING_PORT=6881

# Wireguard PIA
VPN_SERVICE_PROVIDER=private internet access # VPN service provider
OPENVPN_USER=username
OPENVPN_PASSWORD=password
SERVER_REGIONS=Ireland # PIA server region
PIA_LOC=ireland # PIA location
# Optional: DNS lines written into WireGuard config only (not required for startup). Leave unset to use PIA DNS after addKey.
VPNDNS=10.0.0.243,10.0.0.242
LOCAL_NETWORK=192.168.0.0/24 # Local network
